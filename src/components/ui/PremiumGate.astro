---
/**
 * PremiumGate — Wraps content that requires premium.
 * Free users see a blurred overlay with upgrade CTA.
 * Premium users see the content normally.
 *
 * Usage:
 *   <PremiumGate isPremium={premium.isPremium} feature="weightChart">
 *     <WeightChart ... />
 *   </PremiumGate>
 */
interface Props {
  isPremium: boolean;
  feature?: string;
  title?: string;
  description?: string;
}

const {
  isPremium,
  feature = '',
  title = 'Funcion Premium',
  description = 'Desbloquea esta funcion con PetLog Premium.',
} = Astro.props;
---

{isPremium ? (
  <slot />
) : (
  <div class="relative">
    <!-- Blurred content preview -->
    <div class="pointer-events-none select-none" style="filter:blur(4px);opacity:0.5;" aria-hidden="true">
      <slot />
    </div>
    <!-- Overlay CTA -->
    <div class="absolute inset-0 flex items-center justify-center z-10">
      <div class="bg-card/95 backdrop-blur-sm border border-card-border rounded-2xl px-6 py-5 text-center max-w-xs shadow-lg">
        <div class="mx-auto mb-3 flex h-11 w-11 items-center justify-center rounded-xl bg-accent/10">
          <svg class="h-5 w-5 text-accent" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><polygon points="12 2 15.09 8.26 22 9.27 17 14.14 18.18 21.02 12 17.77 5.82 21.02 7 14.14 2 9.27 8.91 8.26 12 2"/></svg>
        </div>
        <p class="text-sm font-bold text-ink mb-1">{title}</p>
        <p class="text-xs text-muted mb-4 leading-relaxed">{description}</p>
        <a
          href="/premium"
          class="inline-flex items-center gap-1.5 rounded-xl px-5 py-2.5 text-xs font-semibold text-white transition-all active:scale-95"
          style="background:#F97316;box-shadow:0 3px 10px rgba(249,115,22,0.3);"
          data-feature={feature}
        >
          <svg class="h-3.5 w-3.5" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><polygon points="12 2 15.09 8.26 22 9.27 17 14.14 18.18 21.02 12 17.77 5.82 21.02 7 14.14 2 9.27 8.91 8.26 12 2"/></svg>
          Desbloquear Premium
        </a>
      </div>
    </div>
  </div>
)}
