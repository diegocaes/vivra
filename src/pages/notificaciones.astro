---
import MainLayout from '../layouts/MainLayout.astro';
import { timeAgo } from '../lib/utils';
import { getActivePet } from '../lib/pet';

const { supabase, user, activePetId } = Astro.locals;
const { pet: activePet } = await getActivePet(supabase, user.id, activePetId);

// Handle clear all action
if (Astro.request.method === 'POST') {
  const formData = await Astro.request.formData();
  if (formData.get('_action') === 'clear_all') {
    let delQuery = supabase.from('notifications').delete().eq('user_id', user.id);
    if (activePet) delQuery = delQuery.eq('pet_id', activePet.id);
    await delQuery;
    return Astro.redirect('/notificaciones?cleared=1');
  }
}

// Mark all as read on page visit (only for active pet)
let markQuery = supabase
  .from('notifications')
  .update({ read: true })
  .eq('user_id', user.id)
  .eq('read', false);
if (activePet) markQuery = markQuery.eq('pet_id', activePet.id);
await markQuery;

// Fetch notifications for active pet (most recent first, last 50)
let fetchQuery = supabase
  .from('notifications')
  .select('id, type, title, message, icon, href, read, created_at, pet_id')
  .eq('user_id', user.id)
  .order('created_at', { ascending: false })
  .limit(50);
if (activePet) fetchQuery = fetchQuery.eq('pet_id', activePet.id);
const { data: notifications } = await fetchQuery;

const items = notifications ?? [];
const cleared = Astro.url.searchParams.has('cleared');
---

<MainLayout title="Notificaciones">

  <div class="mb-6 animate-fade-up flex items-start justify-between">
    <div>
      <h1 class="text-xl font-bold text-ink">Notificaciones</h1>
      <p class="text-sm text-muted mt-0.5">Logros, mejoras y novedades</p>
    </div>
    {items.length > 0 && (
      <form method="POST">
        <input type="hidden" name="_action" value="clear_all" />
        <button
          type="submit"
          onclick="return confirm('¿Borrar todas las notificaciones?')"
          class="flex items-center gap-1.5 rounded-xl border border-card-border bg-card px-3 py-2 text-xs font-medium text-muted hover:text-red-500 hover:border-red-200 transition-colors"
        >
          <svg class="h-3.5 w-3.5" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M3 6h18"/><path d="M19 6v14c0 1-1 2-2 2H7c-1 0-2-1-2-2V6"/><path d="M8 6V4c0-1 1-2 2-2h4c1 0 2 1 2 2v2"/></svg>
          Limpiar todo
        </button>
      </form>
    )}
  </div>

  {items.length === 0 ? (
    <div class="rounded-2xl bg-card border border-card-border p-10 text-center animate-fade-up">
      <div class="mx-auto mb-4 flex h-14 w-14 items-center justify-center rounded-xl bg-canvas border border-card-border animate-float">
        <svg class="h-7 w-7 text-muted" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5">
          <path d="M6 8a6 6 0 0 1 12 0c0 7 3 9 3 9H3s3-2 3-9"/><path d="M10.3 21a1.94 1.94 0 0 0 3.4 0"/>
        </svg>
      </div>
      <p class="text-sm font-semibold text-ink">Sin notificaciones</p>
      <p class="text-xs text-muted mt-1.5 max-w-xs mx-auto leading-relaxed">
        Aquí aparecerán tus logros, mejoras en el score de bienestar y novedades importantes.
      </p>
    </div>
  ) : (
    <div class="space-y-2 animate-fade-up">
      {items.map((n) => (
        <a
          href={n.href || '#'}
          class="flex items-start gap-3 rounded-2xl bg-card border border-card-border px-4 py-3.5 transition-all hover:border-accent/30 active:scale-[0.98]"
        >
          <div class="flex h-10 w-10 shrink-0 items-center justify-center rounded-xl bg-accent/10 text-lg">
            {n.icon || '🔔'}
          </div>
          <div class="flex-1 min-w-0">
            <p class="text-sm font-semibold text-ink leading-snug">{n.title}</p>
            <p class="text-xs text-muted mt-0.5 leading-relaxed">{n.message}</p>
            <p class="text-[10px] text-muted/60 mt-1">{timeAgo(n.created_at)}</p>
          </div>
          <svg class="h-4 w-4 text-muted/30 shrink-0 mt-1" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="m9 18 6-6-6-6"/></svg>
        </a>
      ))}
    </div>
  )}

</MainLayout>
