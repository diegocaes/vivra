---
import MainLayout from '../../layouts/MainLayout.astro';

import { formatDate } from '../../lib/utils';
import { getActivePet } from '../../lib/pet';

const { supabase, user, activePetId } = Astro.locals;
const { pet } = await getActivePet(supabase, user.id, activePetId);
if (!pet) return Astro.redirect('/perfil?new=1');

if (Astro.request.method === 'POST') {
  const formData = await Astro.request.formData();
  const action = formData.get('_action') as string;

  if (action === 'add') {
    await supabase.from('activity_logs').insert({
      pet_id: pet.id,
      date: formData.get('date') as string,
      walks: Number(formData.get('walks')) || 0,
      duration_minutes: Number(formData.get('duration_minutes')) || null,
      notes: (formData.get('notes') as string) || null,
    });
    return Astro.redirect('/salud/actividad?saved=1');
  }

  if (action === 'delete') {
    await supabase.from('activity_logs').delete().eq('id', formData.get('id') as string).eq('pet_id', pet.id);
    return Astro.redirect('/salud/actividad?deleted=1');
  }
}

// Load recent activity logs
const { data: logs } = await supabase
  .from('activity_logs')
  .select('*')
  .eq('pet_id', pet.id)
  .order('date', { ascending: false })
  .limit(30);

// Stats
const thisWeek = (logs ?? []).filter(l => {
  const d = new Date(l.date + 'T00:00:00');
  const now = new Date();
  const diff = Math.ceil((now.getTime() - d.getTime()) / 86400000);
  return diff <= 7;
});
const weekWalks = thisWeek.reduce((s: number, l: any) => s + (l.walks || 0), 0);
const weekMinutes = thisWeek.reduce((s: number, l: any) => s + (l.duration_minutes || 0), 0);
const daysActive = thisWeek.length;

const today = new Date().toISOString().split('T')[0];
const todayLog = (logs ?? []).find(l => l.date === today);
---

<MainLayout title="Actividad">
  <a href="/salud" class="inline-flex items-center gap-1.5 text-sm text-muted hover:text-ink transition-colors mb-4">
    <svg class="h-4 w-4" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M15 18l-6-6 6-6"/></svg>
    Salud
  </a>

  {/* ── STATS CARDS ── */}
  <div class="grid grid-cols-3 gap-3 mb-5 animate-fade-up">
    <div class="rounded-2xl bg-card border border-card-border px-4 py-3 text-center">
      <p class="text-lg font-black text-ink">{daysActive}</p>
      <p class="text-[10px] text-muted font-medium mt-0.5">días activo</p>
      <p class="text-[9px] text-muted/60">esta semana</p>
    </div>
    <div class="rounded-2xl bg-card border border-card-border px-4 py-3 text-center">
      <p class="text-lg font-black text-ink">{weekWalks}</p>
      <p class="text-[10px] text-muted font-medium mt-0.5">paseos</p>
      <p class="text-[9px] text-muted/60">esta semana</p>
    </div>
    <div class="rounded-2xl bg-card border border-card-border px-4 py-3 text-center">
      <p class="text-lg font-black text-ink">{weekMinutes > 0 ? `${weekMinutes}` : '—'}</p>
      <p class="text-[10px] text-muted font-medium mt-0.5">minutos</p>
      <p class="text-[9px] text-muted/60">esta semana</p>
    </div>
  </div>

  {/* ── QUICK LOG (today) ── */}
  <div class="mb-5 animate-fade-up animate-fade-up-delay-1">
    <div class="rounded-2xl bg-card border border-card-border p-5">
      <div class="flex items-center gap-2.5 mb-4">
        <div class="flex h-8 w-8 items-center justify-center rounded-xl bg-green-50">
          <svg class="h-4 w-4 text-green-600" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M13 2L3 14h9l-1 8 10-12h-9l1-8z"/></svg>
        </div>
        <div>
          <p class="text-sm font-bold text-ink">Registrar actividad</p>
          <p class="text-[11px] text-muted">{todayLog ? 'Ya registraste hoy' : 'Registra los paseos de hoy'}</p>
        </div>
      </div>

      <form method="POST" class="space-y-3">
        <input type="hidden" name="_action" value="add" />

        <div>
          <label class="block text-xs font-medium text-muted mb-1">Fecha</label>
          <input type="date" name="date" value={today} required class="w-full rounded-xl border border-card-border bg-canvas px-3 py-2.5 text-sm text-ink focus:outline-none focus:border-accent transition-colors" />
        </div>

        <div class="grid grid-cols-2 gap-3">
          <div>
            <label class="block text-xs font-medium text-muted mb-1">Paseos</label>
            <select name="walks" class="w-full rounded-xl border border-card-border bg-canvas px-3 py-2.5 text-sm text-ink focus:outline-none focus:border-accent transition-colors">
              <option value="0">No salió</option>
              <option value="1" selected>1 paseo</option>
              <option value="2">2 paseos</option>
              <option value="3">3 paseos</option>
              <option value="4">4+ paseos</option>
            </select>
          </div>
          <div>
            <label class="block text-xs font-medium text-muted mb-1">Duración total (min)</label>
            <input type="number" name="duration_minutes" placeholder="Ej: 30" min="0" class="w-full rounded-xl border border-card-border bg-canvas px-3 py-2.5 text-sm text-ink focus:outline-none focus:border-accent transition-colors" />
          </div>
        </div>

        <div>
          <label class="block text-xs font-medium text-muted mb-1">Notas (opcional)</label>
          <input type="text" name="notes" placeholder="Ej: Jugó en el parque, llovió..." class="w-full rounded-xl border border-card-border bg-canvas px-3 py-2.5 text-sm text-ink focus:outline-none focus:border-accent transition-colors" />
        </div>

        <button type="submit" class="w-full rounded-xl bg-accent text-white font-semibold py-2.5 text-sm hover:bg-accent-dark transition-colors active:scale-95">
          Guardar
        </button>
      </form>
    </div>
  </div>

  {/* ── HISTORY ── */}
  <div class="mb-6 animate-fade-up animate-fade-up-delay-2">
    <p class="text-xs font-semibold text-muted uppercase tracking-widest mb-3">Historial reciente</p>
    {(!logs || logs.length === 0) ? (
      <div class="rounded-2xl bg-card border border-dashed border-card-border p-6 text-center">
        <p class="text-sm text-muted">Sin registros de actividad</p>
        <p class="text-xs text-muted/60 mt-1">Registra el primer paseo de {pet.name}</p>
      </div>
    ) : (
      <div class="rounded-2xl bg-card border border-card-border divide-y divide-card-border overflow-hidden">
        {logs.map((log: any) => (
          <div class="flex items-center gap-3 px-4 py-3">
            <div class:list={[
              'h-9 w-9 shrink-0 flex items-center justify-center rounded-xl text-sm font-bold',
              log.walks > 0 ? 'bg-green-50 text-green-600' : 'bg-red-50 text-red-400'
            ]}>
              {log.walks > 0 ? log.walks : '✗'}
            </div>
            <div class="flex-1 min-w-0">
              <p class="text-sm font-semibold text-ink">
                {log.walks === 0 ? 'No salió' : `${log.walks} paseo${log.walks > 1 ? 's' : ''}`}
                {log.duration_minutes ? ` · ${log.duration_minutes} min` : ''}
              </p>
              <p class="text-[11px] text-muted">{formatDate(log.date)}</p>
              {log.notes && <p class="text-[11px] text-muted/70 truncate mt-0.5">{log.notes}</p>}
            </div>
            <form method="POST">
              <input type="hidden" name="_action" value="delete" />
              <input type="hidden" name="id" value={log.id} />
              <button type="submit" class="p-1.5 rounded-lg text-muted/40 hover:text-red-400 hover:bg-red-50 transition-colors">
                <svg class="h-4 w-4" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M3 6h18M19 6v14a2 2 0 0 1-2 2H7a2 2 0 0 1-2-2V6M8 6V4a2 2 0 0 1 2-2h4a2 2 0 0 1 2 2v2"/></svg>
              </button>
            </form>
          </div>
        ))}
      </div>
    )}
  </div>

  <p class="mt-10 mb-4 text-center text-xs text-muted/40 leading-relaxed max-w-xs mx-auto">Registra la actividad diaria de {pet.name}. Registrar va a permitir mantener un historial para medir su bienestar.</p>

</MainLayout>
