---
import MainLayout from '../layouts/MainLayout.astro';
import { getPremiumStatus } from '../lib/premium';
import type { PremiumStatus } from '../lib/premium';

const { supabase, user } = Astro.locals;
const premium: PremiumStatus = await getPremiumStatus(supabase, user.id);

const features = [
  { icon: '🐾', name: 'Mascotas ilimitadas', desc: 'Registra todos tus perros en una sola cuenta', free: '1 mascota', premium: 'Hasta 10' },
  { icon: '📊', name: 'Grafica de peso', desc: 'Visualiza la evolucion del peso con graficas detalladas', free: 'Ultimo peso', premium: 'Historial completo' },
  { icon: '🧡', name: 'Score detallado', desc: 'Desglose por pilar, flags y recomendaciones personalizadas', free: 'Score general', premium: 'Detalle completo' },
  { icon: '🍖', name: 'Inventario de comida', desc: 'Alertas de stock, costo por dia y analytics', free: 'Registro basico', premium: 'Inventario + analytics' },
  { icon: '✈️', name: 'Documentos de viaje', desc: 'Sube documentos y genera pasaporte imprimible', free: '2 vuelos', premium: 'Ilimitados + docs' },
  { icon: '📋', name: 'Exportar datos', desc: 'Descarga todo el historial de tu mascota en PDF', free: 'No', premium: 'PDF + CSV' },
  { icon: '🔔', name: 'Push notifications', desc: 'Recordatorios automaticos en tu celular', free: 'In-app', premium: 'Push nativo' },
];
---

<MainLayout title="Premium">
  <div class="max-w-lg mx-auto space-y-6 animate-fade-up">

    <!-- Header -->
    <div class="text-center">
      <div class="mx-auto mb-4 flex h-16 w-16 items-center justify-center rounded-2xl bg-accent/10">
        <svg class="h-8 w-8 text-accent" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5"><polygon points="12 2 15.09 8.26 22 9.27 17 14.14 18.18 21.02 12 17.77 5.82 21.02 7 14.14 2 9.27 8.91 8.26 12 2"/></svg>
      </div>
      <h1 class="text-2xl font-bold text-ink">PetLog Premium</h1>
      <p class="text-sm text-muted mt-1">Desbloquea refiriendo amigos o con una suscripción</p>
    </div>

    <!-- Current status -->
    {premium.isPremium ? (
      <div class="rounded-2xl border border-accent/30 bg-accent/5 px-5 py-4">
        <div class="flex items-center gap-3">
          <div class="flex h-10 w-10 shrink-0 items-center justify-center rounded-xl bg-accent/15">
            <svg class="h-5 w-5 text-accent" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><polyline points="20 6 9 17 4 12"/></svg>
          </div>
          <div>
            <p class="text-sm font-bold text-accent-dark">Premium activo</p>
            <p class="text-xs text-muted">
              {premium.daysLeft} dias restantes
              {premium.isTrial ? ' (trial por referido)' : premium.source === 'referral' ? ' (por referidos)' : ''}
            </p>
          </div>
        </div>
        {premium.isExpiringSoon && (
          <p class="text-xs text-amber-600 mt-3 font-medium">Tu premium vence pronto. Refiere amigos para extenderlo gratis.</p>
        )}
      </div>
    ) : (
      <div class="rounded-2xl border border-card-border bg-canvas px-5 py-4">
        <div class="flex items-center gap-3">
          <div class="flex h-10 w-10 shrink-0 items-center justify-center rounded-xl bg-canvas border border-card-border">
            <svg class="h-5 w-5 text-muted" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><polygon points="12 2 15.09 8.26 22 9.27 17 14.14 18.18 21.02 12 17.77 5.82 21.02 7 14.14 2 9.27 8.91 8.26 12 2"/></svg>
          </div>
          <div>
            <p class="text-sm font-bold text-ink">Plan gratuito</p>
            <p class="text-xs text-muted">Funciones basicas para 1 mascota</p>
          </div>
        </div>
      </div>
    )}

    <!-- Feature comparison -->
    <div class="rounded-2xl border border-card-border bg-card overflow-hidden">
      <div class="grid grid-cols-3 gap-0 border-b border-card-border bg-canvas px-4 py-3">
        <p class="text-xs font-semibold text-muted uppercase tracking-wider col-span-1">Funcion</p>
        <p class="text-xs font-semibold text-muted uppercase tracking-wider text-center">Free</p>
        <p class="text-xs font-semibold text-accent uppercase tracking-wider text-center">Premium</p>
      </div>
      {features.map((f, i) => (
        <div class:list={['grid grid-cols-3 gap-0 px-4 py-3 items-center', i < features.length - 1 && 'border-b border-card-border']}>
          <div class="flex items-center gap-2 col-span-1">
            <span class="text-base">{f.icon}</span>
            <div>
              <p class="text-xs font-semibold text-ink">{f.name}</p>
              <p class="text-xs text-muted leading-tight hidden sm:block">{f.desc}</p>
            </div>
          </div>
          <p class="text-xs text-muted text-center">{f.free}</p>
          <p class="text-xs text-accent-dark font-semibold text-center">{f.premium}</p>
        </div>
      ))}
    </div>

    <!-- How to get premium -->
    <div class="rounded-2xl border border-card-border bg-card p-5">
      <p class="text-xs font-semibold text-muted uppercase tracking-wider mb-4">Como obtener premium</p>
      <div class="space-y-4">
        <div class="flex items-start gap-3">
          <div class="flex h-8 w-8 shrink-0 items-center justify-center rounded-full bg-accent/10 text-sm">🎁</div>
          <div>
            <p class="text-sm font-medium text-ink">Refiere amigos</p>
            <p class="text-xs text-muted mt-0.5">Cada amigo que se une = 1 mes premium gratis para ti</p>
          </div>
        </div>
        <div class="flex items-start gap-3">
          <div class="flex h-8 w-8 shrink-0 items-center justify-center rounded-full bg-accent/10 text-sm">💳</div>
          <div>
            <p class="text-sm font-medium text-ink">Suscripción mensual</p>
            <p class="text-xs text-muted mt-0.5">$2.99/mes o $19.99/año — todo ilimitado</p>
          </div>
        </div>
      </div>
    </div>

    <!-- CTA -->
    {!premium.isPremium && (
      <a
        href="/referidos"
        class="flex items-center justify-center gap-2 w-full rounded-2xl px-6 py-3.5 text-sm font-semibold text-white transition-all active:scale-95"
        style="background:#F97316;box-shadow:0 4px 14px rgba(249,115,22,0.35);"
      >
        <svg class="h-4 w-4" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><circle cx="18" cy="5" r="3"/><circle cx="6" cy="12" r="3"/><circle cx="18" cy="19" r="3"/><line x1="8.59" y1="13.51" x2="15.42" y2="17.49"/><line x1="15.41" y1="6.51" x2="8.59" y2="10.49"/></svg>
        Invitar amigos y ganar premium
      </a>
    )}

  </div>
</MainLayout>
