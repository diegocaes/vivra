                    <button type="submit" class="shrink-0 rounded-xl bg-accent/10 px-3 py-2 text-xs font-medium text-accent hover:bg-accent/20 active:scale-95 transition-colors">Subir</button>
                  </form>
                </div>

                {/* Actions */}
                <div class="flex gap-2 pt-1 border-t border-card-border/50">
                  <button type="button" class="edit-btn flex-1 rounded-xl border border-card-border px-3 py-2 text-xs font-semibold text-muted hover:text-ink hover:border-accent/30 transition-colors" data-id={flight.id}>
                    Editar
                  </button>
                  <form method="POST" class="flex-1">
                    <input type="hidden" name="_action" value="delete_flight" />
