    document.addEventListener('astro:page-load', function() {
      // Tabs
      var tabs = document.querySelectorAll('.viajes-tab');
      var panels = document.querySelectorAll('.viajes-panel');
      function setTab(name) {
        tabs.forEach(function(t) {
          if (t.dataset.tab === name) {
            t.classList.add('bg-accent', 'text-white');
            t.classList.remove('text-muted');
          } else {
            t.classList.remove('bg-accent', 'text-white');
            t.classList.add('text-muted');
          }
        });
        panels.forEach(function(p) {
          if (p.dataset.panel === name) {
            p.classList.remove('hidden');
          } else {
            p.classList.add('hidden');
          }
        });
      }
      tabs.forEach(function(t) {
        t.addEventListener('click', function() { setTab(t.dataset.tab); });
      });
      // Default: show upcoming if any, else history
      var upcomingPanel = document.querySelector('.viajes-panel[data-panel="upcoming"]');
      var hasUpcoming = upcomingPanel && upcomingPanel.querySelector('.rounded-2xl.bg-card:not(.border-dashed)');
      setTab(hasUpcoming ? 'upcoming' : 'history');

      // Toggle flight details
      document.querySelectorAll('.toggle-flight').forEach(function(btn) {
        btn.addEventListener('click', function() {
          var id = btn.dataset.id;
          var details = document.querySelectorAll('.flight-details[data-id="' + id + '"]');
          details.forEach(function(d) { d.classList.toggle('hidden'); });
          var chevron = btn.querySelector('.chevron-icon');
          if (chevron) chevron.classList.toggle('rotate-180');
        });
      });

      // Edit / cancel
      document.querySelectorAll('.edit-btn').forEach(function(btn) {
        btn.addEventListener('click', function() {
          var id = btn.dataset.id;
          var editForm = btn.closest('.flight-details').querySelector('.item-edit[data-id="' + id + '"]');
          if (editForm) editForm.classList.remove('hidden');
          btn.closest('.space-y-3').classList.add('hidden');
        });
      });
      document.querySelectorAll('.cancel-edit').forEach(function(btn) {
        btn.addEventListener('click', function() {
          var id = btn.dataset.id;
          var editForm = btn.closest('.item-edit');
          if (editForm) editForm.classList.add('hidden');
          var content = editForm.previousElementSibling || editForm.closest('.flight-details').querySelector('.space-y-3');
          if (content) content.classList.remove('hidden');
        });
      });
    });
  </script>

  <p class="mt-10 mb-4 text-center text-xs text-muted/40 leading-relaxed max-w-xs mx-auto">Viajar con tu mascota requiere planificación. Registra cada vuelo con documentos y requisitos para que todo esté listo.</p>

</MainLayout>
