---
import MainLayout from '../layouts/MainLayout.astro';
import { formatDate } from '../lib/utils';
import { getActivePet } from '../lib/pet';

const { supabase, user, activePetId } = Astro.locals;
const { pet } = await getActivePet(supabase, user.id, activePetId);
if (!pet) return Astro.redirect('/perfil?new=1');

// Fetch all date-relevant data in parallel
const [vaccinesRes, visitsRes, groomingsRes, flightsRes, preventivesRes] = await Promise.all([
  supabase.from('vaccines').select('id, name, date_given, next_due').eq('pet_id', pet.id),
  supabase.from('vet_visits').select('id, reason, date, vet_name').eq('pet_id', pet.id),
  supabase.from('groomings').select('id, type, date, groomer_name').eq('pet_id', pet.id),
  supabase.from('flights').select('id, origin, destination, flight_date, airline').eq('pet_id', pet.id),
  supabase.from('preventive_treatments').select('id, type, date_given, product_name').eq('pet_id', pet.id),
]);

// Blood tests (table may not exist yet)
let bloodTestsData: { id: string; date: string }[] = [];
try {
  const { data } = await supabase.from('blood_tests').select('id, date').eq('pet_id', pet.id);
  bloodTestsData = data ?? [];
} catch { /* table may not exist yet */ }

interface CalendarEvent {
  id: string;
  date: string;
  title: string;
  subtitle: string;
  category: 'vaccine' | 'vet' | 'grooming' | 'flight' | 'preventive' | 'reminder' | 'blood_test';
  icon: string;
  color: string;
  href: string;
}

const events: CalendarEvent[] = [];

// Vaccines (past + upcoming)
for (const v of vaccinesRes.data ?? []) {
  events.push({
    id: `vac-${v.id}`,
    date: v.date_given,
    title: v.name,
    subtitle: 'Vacuna aplicada',
    category: 'vaccine',
    icon: '💉',
    color: 'bg-blue-50 text-blue-600 border-blue-100',
    href: '/salud/vacunas',
  });
  if (v.next_due) {
    events.push({
      id: `vac-next-${v.id}`,
      date: v.next_due,
      title: `${v.name} (refuerzo)`,
      subtitle: 'Próxima dosis',
      category: 'reminder',
      icon: '🔔',
      color: 'bg-amber-50 text-amber-600 border-amber-100',
      href: '/salud/vacunas',
    });
  }
}

// Vet visits
for (const v of visitsRes.data ?? []) {
  events.push({
    id: `vet-${v.id}`,
    date: v.date,
    title: v.reason,
    subtitle: v.vet_name ? `Dr. ${v.vet_name}` : 'Visita veterinaria',
    category: 'vet',
    icon: '🏥',
    color: 'bg-purple-50 text-purple-600 border-purple-100',
    href: '/salud/historial',
  });
}

// Grooming
for (const g of groomingsRes.data ?? []) {
  events.push({
    id: `groom-${g.id}`,
    date: g.date,
    title: g.type || 'Grooming',
    subtitle: g.groomer_name || 'Estética',
    category: 'grooming',
    icon: '✂️',
    color: 'bg-pink-50 text-pink-600 border-pink-100',
    href: '/salud/grooming',
  });
}

// Flights
for (const f of flightsRes.data ?? []) {
  events.push({
    id: `flight-${f.id}`,
    date: f.flight_date,
    title: `${f.origin} → ${f.destination}`,
    subtitle: f.airline || 'Vuelo',
    category: 'flight',
    icon: '✈️',
    color: 'bg-accent/10 text-accent border-accent/20',
    href: '/viajes',
  });
}

// Preventive treatments (past + next dose in 30 days)
for (const p of preventivesRes.data ?? []) {
  events.push({
    id: `prev-${p.id}`,
    date: p.date_given,
    title: p.product_name || (p.type === 'antipulgas' ? 'Antipulgas' : 'Desparasitante'),
    subtitle: p.type === 'antipulgas' ? 'Antipulgas aplicado' : 'Desparasitante aplicado',
    category: 'preventive',
    icon: p.type === 'antipulgas' ? '🐛' : '💊',
    color: 'bg-green-50 text-green-600 border-green-100',
    href: '/salud/preventivos',
  });
}

// Preventive next-dose reminders (30-day cycle from last application per type)
const preventivesByType: Record<string, string[]> = {};
for (const p of preventivesRes.data ?? []) {
  if (!preventivesByType[p.type]) preventivesByType[p.type] = [];
  preventivesByType[p.type].push(p.date_given);
}
for (const [type, dates] of Object.entries(preventivesByType)) {
  const sorted = dates.sort((a, b) => b.localeCompare(a));
  const lastDate = sorted[0];
  const nextDate = new Date(lastDate + 'T00:00:00');
  nextDate.setDate(nextDate.getDate() + 30);
  const nextStr = nextDate.toISOString().split('T')[0];
  events.push({
    id: `prev-next-${type}`,
    date: nextStr,
    title: type === 'antipulgas' ? 'Próximo antipulgas' : 'Próximo desparasitante',
    subtitle: 'Siguiente dosis',
    category: 'reminder',
    icon: '🔔',
    color: 'bg-amber-50 text-amber-600 border-amber-100',
    href: '/salud/preventivos',
  });
}

// Blood tests (past + annual reminder)
for (const bt of bloodTestsData) {
  events.push({
    id: `blood-${bt.id}`,
    date: bt.date,
    title: 'Examen de sangre',
    subtitle: 'Análisis realizado',
    category: 'blood_test',
    icon: '🩸',
    color: 'bg-red-50 text-red-600 border-red-100',
    href: '/salud',
  });
}
// Next annual blood test reminder
if (bloodTestsData.length > 0) {
  const lastBlood = bloodTestsData.sort((a, b) => b.date.localeCompare(a.date))[0];
  const nextBlood = new Date(lastBlood.date + 'T00:00:00');
  nextBlood.setFullYear(nextBlood.getFullYear() + 1);
  events.push({
    id: 'blood-next',
    date: nextBlood.toISOString().split('T')[0],
    title: 'Próximo examen de sangre',
    subtitle: 'Recomendado anual',
    category: 'reminder',
    icon: '🔔',
    color: 'bg-amber-50 text-amber-600 border-amber-100',
    href: '/salud',
  });
}

// Sort by date descending
events.sort((a, b) => b.date.localeCompare(a.date));

// Group by month
const grouped: Record<string, CalendarEvent[]> = {};
for (const ev of events) {
  const d = new Date(ev.date + 'T00:00:00');
  const key = `${d.getFullYear()}-${String(d.getMonth() + 1).padStart(2, '0')}`;
  if (!grouped[key]) grouped[key] = [];
  grouped[key].push(ev);
}

const months = Object.keys(grouped).sort((a, b) => b.localeCompare(a));

// Upcoming events (future dates)
const today = new Date().toISOString().split('T')[0];
const todayMonthKey = today.slice(0, 7); // "YYYY-MM"
const upcoming = events.filter(e => e.date >= today).sort((a, b) => a.date.localeCompare(b.date));

function monthLabel(key: string) {
  const [y, m] = key.split('-').map(Number);
  const d = new Date(y, m - 1, 1);
  return d.toLocaleDateString('es', { month: 'long', year: 'numeric' });
}

function dayLabel(dateStr: string) {
  const d = new Date(dateStr + 'T00:00:00');
  return d.toLocaleDateString('es', { weekday: 'short', day: 'numeric' });
}
---

<MainLayout title="Calendario">

  {/* ── HEADER ── */}
  <div class="mb-5 animate-fade-up">
    <h1 class="text-xl font-black text-ink">Calendario</h1>
    <p class="text-xs text-muted mt-0.5">Todas las fechas importantes de {pet.name}</p>
  </div>

  {/* ── UPCOMING REMINDERS ── */}
  {upcoming.length > 0 && (
    <div class="mb-5 animate-fade-up">
      <p class="text-xs font-semibold text-muted uppercase tracking-widest mb-3">Próximos eventos</p>
      <div class="rounded-2xl bg-card border border-card-border divide-y divide-card-border overflow-hidden">
        {upcoming.slice(0, 5).map((ev) => {
          const daysUntil = Math.ceil((new Date(ev.date + 'T00:00:00').getTime() - new Date().setHours(0,0,0,0)) / 86400000);
          return (
            <a href={ev.href} class="flex items-center gap-3 px-4 py-3 hover:bg-canvas/50 transition-colors">
              <div class:list={['h-9 w-9 shrink-0 flex items-center justify-center rounded-xl border text-sm', ev.color]}>
                {ev.icon}
              </div>
              <div class="flex-1 min-w-0">
                <p class="text-sm font-semibold text-ink truncate">{ev.title}</p>
                <p class="text-[11px] text-muted">{ev.subtitle} · {formatDate(ev.date)}</p>
              </div>
              <span class:list={[
                'rounded-full px-2 py-0.5 text-[10px] font-bold shrink-0',
                daysUntil === 0 ? 'bg-red-50 text-red-600' : daysUntil <= 3 ? 'bg-amber-50 text-amber-600' : 'bg-green-50 text-green-700'
              ]}>
                {daysUntil === 0 ? 'Hoy' : daysUntil === 1 ? 'Mañana' : `${daysUntil}d`}
              </span>
            </a>
          );
        })}
      </div>
      {upcoming.length > 5 && (
        <p class="text-center text-[11px] text-muted mt-2">+{upcoming.length - 5} eventos más</p>
      )}
    </div>
  )}

  {/* ── FILTER CHIPS ── */}
  <div class="flex flex-wrap gap-1.5 mb-4 animate-fade-up">
    <button type="button" class="cal-filter rounded-full px-3 py-1.5 text-[11px] font-semibold border transition-colors" data-cat="all">Todo</button>
    <button type="button" class="cal-filter rounded-full px-3 py-1.5 text-[11px] font-semibold border transition-colors" data-cat="vaccine">Vacunas</button>
    <button type="button" class="cal-filter rounded-full px-3 py-1.5 text-[11px] font-semibold border transition-colors" data-cat="vet">Veterinario</button>
    <button type="button" class="cal-filter rounded-full px-3 py-1.5 text-[11px] font-semibold border transition-colors" data-cat="preventive">Preventivos</button>
    <button type="button" class="cal-filter rounded-full px-3 py-1.5 text-[11px] font-semibold border transition-colors" data-cat="flight">Vuelos</button>
    <button type="button" class="cal-filter rounded-full px-3 py-1.5 text-[11px] font-semibold border transition-colors" data-cat="grooming">Estética</button>
    <button type="button" class="cal-filter rounded-full px-3 py-1.5 text-[11px] font-semibold border transition-colors" data-cat="blood_test">Sangre</button>
    <button type="button" class="cal-filter rounded-full px-3 py-1.5 text-[11px] font-semibold border transition-colors" data-cat="reminder">Recordatorios</button>
  </div>

  {/* ── EMPTY STATE ── */}
  {events.length === 0 && (
    <div class="rounded-2xl bg-card border border-dashed border-card-border p-8 text-center animate-fade-up">
      <div class="flex h-14 w-14 items-center justify-center rounded-2xl bg-accent/10 mx-auto mb-4">
        <svg class="h-7 w-7 text-accent" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5">
          <rect x="3" y="4" width="18" height="18" rx="2" ry="2"/><line x1="16" y1="2" x2="16" y2="6"/><line x1="8" y1="2" x2="8" y2="6"/><line x1="3" y1="10" x2="21" y2="10"/>
        </svg>
      </div>
      <p class="text-sm font-semibold text-ink mb-1">Sin eventos</p>
      <p class="text-xs text-muted">Registra vacunas, visitas o vuelos y aparecerán aquí</p>
    </div>
  )}

  {/* ── TIMELINE BY MONTH ── */}
  <div class="space-y-5">
    {months.map((monthKey, mi) => {
      const eventsInMonth = grouped[monthKey];
      const isCurrentMonth = monthKey === todayMonthKey;
      // Split events: future (>= today) and past (< today) — already sorted desc within month
      const hasFuture = isCurrentMonth && eventsInMonth.some(e => e.date >= today);
      const hasPast = isCurrentMonth && eventsInMonth.some(e => e.date < today);
      const showTodayDivider = hasFuture && hasPast;

      return (
        <div class:list={['animate-fade-up', mi < 5 && `animate-fade-up-delay-${Math.min(mi + 1, 5)}`]}>
          <div class="flex items-center gap-2 mb-3">
            <p class="text-xs font-semibold text-muted uppercase tracking-widest">{monthLabel(monthKey)}</p>
            {isCurrentMonth && (
              <span class="rounded-full bg-accent px-2 py-0.5 text-[10px] font-bold text-white">Mes actual</span>
            )}
          </div>
          <div class="rounded-2xl bg-card border border-card-border divide-y divide-card-border overflow-hidden">
            {/* "Hoy" divider at top if current month has only past events */}
            {isCurrentMonth && !hasFuture && hasPast && (
              <div class="flex items-center gap-3 px-4 py-2 bg-accent/5">
                <div class="h-2 w-2 rounded-full bg-accent shrink-0"></div>
                <div class="flex-1 h-px bg-accent/30"></div>
                <span class="text-[11px] font-bold text-accent uppercase tracking-wider">Hoy</span>
                <div class="flex-1 h-px bg-accent/30"></div>
                <div class="h-2 w-2 rounded-full bg-accent shrink-0"></div>
              </div>
            )}
            {eventsInMonth.map((ev, ei) => {
              // Show "HOY" divider before the first past event (events sorted desc: future first, then past)
              const prevEv = ei > 0 ? eventsInMonth[ei - 1] : null;
              const needsDivider = showTodayDivider && ev.date < today && (!prevEv || prevEv.date >= today);
              const isPast = ev.date < today;
              const isToday = ev.date === today;

              return (
                <>
                  {needsDivider && (
                    <div class="flex items-center gap-3 px-4 py-2 bg-accent/5">
                      <div class="h-2 w-2 rounded-full bg-accent shrink-0"></div>
                      <div class="flex-1 h-px bg-accent/30"></div>
                      <span class="text-[11px] font-bold text-accent uppercase tracking-wider">Hoy</span>
                      <div class="flex-1 h-px bg-accent/30"></div>
                      <div class="h-2 w-2 rounded-full bg-accent shrink-0"></div>
                    </div>
                  )}
                  <a
                    href={ev.href}
                    class:list={[
                      'cal-event flex items-center gap-3 px-4 py-3 hover:bg-canvas/50 transition-colors',
                      isPast && !isToday && 'opacity-50',
                      isToday && 'bg-accent/5',
                    ]}
                    data-cat={ev.category}
                  >
                    <div class:list={['h-9 w-9 shrink-0 flex items-center justify-center rounded-xl border text-sm', ev.color]}>
                      {ev.icon}
                    </div>
                    <div class="flex-1 min-w-0">
                      <p class="text-sm font-semibold text-ink truncate">{ev.title}</p>
                      <p class="text-[11px] text-muted">{ev.subtitle}</p>
                    </div>
                    <div class="text-right shrink-0">
                      {isToday ? (
                        <span class="rounded-full bg-accent px-2 py-0.5 text-[10px] font-bold text-white">Hoy</span>
                      ) : (
                        <>
                          <p class="text-xs font-semibold text-ink">{dayLabel(ev.date)}</p>
                          <p class="text-[10px] text-muted">{ev.date.split('-')[0]}</p>
                        </>
                      )}
                    </div>
                  </a>
                </>
              );
            })}
            {/* "Hoy" divider at bottom if current month has only future events */}
            {isCurrentMonth && hasFuture && !hasPast && (
              <div class="flex items-center gap-3 px-4 py-2 bg-accent/5">
                <div class="h-2 w-2 rounded-full bg-accent shrink-0"></div>
                <div class="flex-1 h-px bg-accent/30"></div>
                <span class="text-[11px] font-bold text-accent uppercase tracking-wider">Hoy</span>
                <div class="flex-1 h-px bg-accent/30"></div>
                <div class="h-2 w-2 rounded-full bg-accent shrink-0"></div>
              </div>
            )}
          </div>
        </div>
      );
    })}
  </div>

  <script is:inline>
    document.addEventListener('astro:page-load', function() {
      var filters = document.querySelectorAll('.cal-filter');
      var events = document.querySelectorAll('.cal-event');
      var active = 'all';

      function updateFilters() {
        filters.forEach(function(f) {
          if (f.dataset.cat === active) {
            f.classList.add('bg-accent', 'text-white', 'border-accent');
            f.classList.remove('text-muted', 'border-card-border');
          } else {
            f.classList.remove('bg-accent', 'text-white', 'border-accent');
            f.classList.add('text-muted', 'border-card-border');
          }
        });
        events.forEach(function(ev) {
          if (active === 'all' || ev.dataset.cat === active) {
            ev.classList.remove('hidden');
          } else {
            ev.classList.add('hidden');
          }
        });
        // Hide empty month sections
        document.querySelectorAll('.rounded-2xl.bg-card.divide-y').forEach(function(card) {
          var visibleEvents = card.querySelectorAll('.cal-event:not(.hidden)');
          var wrapper = card.parentElement;
          if (wrapper) {
            if (visibleEvents.length === 0) {
              wrapper.classList.add('hidden');
            } else {
              wrapper.classList.remove('hidden');
            }
          }
        });
      }

      filters.forEach(function(f) {
        f.addEventListener('click', function() {
          active = f.dataset.cat;
          updateFilters();
        });
      });

      updateFilters();
    });
  </script>

  <p class="mt-10 mb-4 text-center text-xs text-muted/40 leading-relaxed max-w-xs mx-auto">Aquí puedes ver todas las fechas importantes de {pet.name}: vacunas, visitas, vuelos y recordatorios en un solo lugar.</p>

</MainLayout>
